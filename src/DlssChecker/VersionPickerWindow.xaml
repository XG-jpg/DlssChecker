<Window x:Class="DlssChecker.VersionPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор версии DLSS"
        Width="420"
        Height="480"
        MinHeight="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackground}"
        Foreground="{StaticResource TextPrimaryBrush}">
    <Grid Margin="20,18,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Версия DLSS"
                       FontSize="15" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,4"/>
            <TextBlock x:Name="CurrentVersionText"
                       FontSize="12"
                       Foreground="{StaticResource TextMutedBrush}"/>
        </StackPanel>

        <!-- Loading state -->
        <StackPanel x:Name="LoadingPanel" Grid.Row="1"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
            <ProgressBar IsIndeterminate="True" Height="6" Width="200" Margin="0,0,0,10"/>
            <TextBlock Text="Загрузка списка версий…"
                       FontSize="12"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Error state -->
        <StackPanel x:Name="ErrorPanel" Grid.Row="1"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="ErrorText"
                       FontSize="12"
                       Foreground="#f85149"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>
        </StackPanel>

        <!-- Version list -->
        <ListBox x:Name="VersionList"
                 Grid.Row="1"
                 Visibility="Collapsed"
                 Background="#0d1825"
                 BorderBrush="{StaticResource CardBorderBrush}"
                 BorderThickness="1"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectionMode="Single">
            <ListBox.Resources>
                <Style TargetType="ScrollBar">
                    <Setter Property="Width" Value="8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="#0d1825">
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="#2a3f5a" CornerRadius="4" Margin="2,2,2,2"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.Resources>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="12,8"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#151f30"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1a2d4a"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="{Binding Version}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <!-- "Актуальная" badge -->
                            <Border Visibility="{Binding IsLatestBadgeVisible}"
                                    Background="#1a3a1a" CornerRadius="4"
                                    Padding="5,2" Margin="0,0,5,0">
                                <TextBlock Text="Актуальная" FontSize="10"
                                           Foreground="#4CAF50"/>
                            </Border>
                            <!-- "Установлена" badge -->
                            <Border Visibility="{Binding IsInstalledBadgeVisible}"
                                    Background="#1a2a3a" CornerRadius="4"
                                    Padding="5,2">
                                <TextBlock Text="Установлена" FontSize="10"
                                           Foreground="#5b9bd5"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DateText}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Bottom buttons -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Обзор…"
                    Width="90"
                    Click="OnBrowseLocal"
                    Background="#151f30"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"/>

            <Button Grid.Column="2"
                    x:Name="InstallButton"
                    Content="Установить"
                    Width="110"
                    IsEnabled="False"
                    Click="OnInstall"/>
        </Grid>
    </Grid>
</Window>
