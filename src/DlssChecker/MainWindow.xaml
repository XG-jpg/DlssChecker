<Window x:Class="DlssChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DLSS Checker"
        SizeToContent="Height"
        Width="900"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackground}"
        Foreground="{StaticResource TextPrimaryBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="HeaderTitleText" FontSize="20" FontWeight="Bold" Margin="0,0,6,0"/>
                        <TextBlock x:Name="HeaderVersionText" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="SubtitleText"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="CheckAppUpdatesButton"
                            Width="168"
                            Margin="12,0,0,0"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            Click="OnCheckAppUpdates">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Width="16" Height="16" Margin="0,0,8,0" Stretch="Uniform"
                                  Fill="{StaticResource TextPrimaryBrush}"
                                  Data="M8 1.5a6.5 6.5 0 1 0 6.09 8.78.75.75 0 0 0-1.41-.5A5 5 0 1 1 8 3a4.96 4.96 0 0 1 3.54 1.46H10.5a.75.75 0 0 0 0 1.5H13a.75.75 0 0 0 .75-.75V2.7a.75.75 0 0 0-1.5 0v.86A6.46 6.46 0 0 0 8 1.5Z"/>
                            <TextBlock x:Name="CheckAppUpdatesButtonText" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="GithubButton"
                            Width="108"
                            Margin="12,0,0,0"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            Click="OnOpenGithub">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Width="16" Height="16" Margin="0,0,8,0" Stretch="Uniform"
                                  Fill="{StaticResource TextPrimaryBrush}"
                                  Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
                            <TextBlock x:Name="GithubButtonText" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── DLSS ── -->
        <Border Grid.Row="1"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="GameFolderTitleText" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <!-- Path + Browse -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="GamePathBox" Grid.Column="0" MinWidth="520" Height="34" TextAlignment="Center"/>
                    <Button x:Name="BrowseButton" Grid.Column="1" Width="90" Margin="8,0,0,0" Click="OnBrowse"/>
                </Grid>

                <!-- Detected games tiles -->
                <Border x:Name="GamesPanelBorder"
                        Visibility="Collapsed"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="0,8,0,8"
                        Margin="0,0,0,8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock x:Name="DetectedGamesTitleText"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                            <ProgressBar x:Name="GameScanBar"
                                         Width="80" Height="6"
                                         IsIndeterminate="True"
                                         Visibility="Collapsed"
                                         Margin="8,0,0,0"
                                         VerticalAlignment="Center"/>
                        </StackPanel>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      MaxHeight="116">
                            <ItemsControl x:Name="GameTilesList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="GameTile"
                                                CornerRadius="8"
                                                Width="96"
                                                Height="100"
                                                Margin="0,0,6,6"
                                                Cursor="Hand"
                                                ToolTip="{Binding FolderPath}"
                                                MouseLeftButtonUp="OnGameTileClick">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1E1E1E"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#2A2A2A"/>
                                                            <Setter Property="BorderBrush" Value="#555"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="#1A2A1A"/>
                                                            <Setter Property="BorderBrush" Value="#4CAF50"/>
                                                            <Setter Property="BorderThickness" Value="2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <!-- Icon or placeholder -->
                                                    <Grid Width="36" Height="36" HorizontalAlignment="Center">
                                                        <Rectangle Width="36" Height="36" RadiusX="6" RadiusY="6" Fill="#333"/>
                                                        <Image Source="{Binding Icon}"
                                                               Width="32" Height="32"
                                                               Stretch="Uniform"
                                                               RenderOptions.BitmapScalingMode="HighQuality"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <!-- Game name -->
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="11"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               MaxWidth="88"
                                                               Margin="2,5,2,0"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               MaxHeight="32"/>
                                                    <!-- DLSS version -->
                                                    <TextBlock Text="{Binding DlssVersion}"
                                                               FontSize="10"
                                                               TextAlignment="Center"
                                                               Margin="2,2,2,0"
                                                               Foreground="{StaticResource TextMutedBrush}"/>
                                                </StackPanel>
                                                <!-- Update status dot -->
                                                <Ellipse Width="9" Height="9"
                                                         HorizontalAlignment="Right" VerticalAlignment="Top"
                                                         Margin="0,5,5,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding NeedsUpdate}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Fill" Value="#FFA726"/>
                                                                    <Setter Property="ToolTip" Value="Доступно обновление DLSS"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding NeedsUpdate}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Fill" Value="#4CAF50"/>
                                                                    <Setter Property="ToolTip" Value="DLSS актуален"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- DLSS info grid -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.9*"/>
                        <ColumnDefinition Width="2.5*"/>
                        <ColumnDefinition Width="0.9*"/>
                        <ColumnDefinition Width="0.9*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock x:Name="SupportLabelText" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="SupportDot" Width="10" Height="10" Margin="0,4,4,0" Fill="{StaticResource TextMutedBrush}"/>
                            <TextBlock x:Name="DlssSupportText" Text="-" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock x:Name="DllLabelText" FontWeight="SemiBold"/>
                        <TextBlock x:Name="DllPathText" Text="-" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock x:Name="GameVersionLabelText" FontWeight="SemiBold"/>
                        <TextBlock x:Name="CurrentVersionText" Text="-" Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock x:Name="LatestVersionLabelText" FontWeight="SemiBold"/>
                        <TextBlock x:Name="LatestVersionText" Text="-" Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                </Grid>

                <WrapPanel Margin="0,0,0,6">
                    <Button x:Name="UpdateButton" Width="165" Margin="0,0,8,0" Click="OnUpdateDlss"/>
                    <Button x:Name="VersionButton" Width="165" Margin="0,0,8,0" Click="OnSelectVersion" Style="{StaticResource DangerButtonStyle}"/>
                </WrapPanel>
                <TextBlock x:Name="UpdateStatusText" Foreground="{StaticResource TextMutedBrush}" Margin="2,0,0,10"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Visibility="{Binding ElementName=BusyBar, Path=Visibility}">
                    <ProgressBar x:Name="BusyBar"
                                 Width="200"
                                 Height="10"
                                 IsIndeterminate="True"
                                 Visibility="Collapsed"/>
                    <TextBlock x:Name="BusyProgressText"
                               FontSize="11"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextMutedBrush}"
                               Visibility="Collapsed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── DLSSTweaks ── -->
        <Border Grid.Row="2"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="TweaksTitleText" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBlock x:Name="TweaksVersionText"
                           FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                    <TextBlock x:Name="PresetLabelText" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="PresetBox" Width="240" SelectedIndex="0" Margin="0,0,8,0">
                        <ComboBoxItem x:Name="PresetHighText" Content="RTX 4000 / 5000"/>
                        <ComboBoxItem x:Name="PresetMidText" Content="RTX 3000"/>
                    </ComboBox>
                    <Button x:Name="ApplyTweaksButton" Width="140" Margin="0,0,8,0" Click="OnApplyTweaks"/>
                </StackPanel>
                <WrapPanel Margin="0,4,0,0" VerticalAlignment="Center">
                    <Button x:Name="EnableOverrideButton" Width="160" Margin="0,0,8,0" Click="OnEnableOverride" Visibility="Collapsed"/>
                    <Button x:Name="RemoveTweaksButton" Width="110" Click="OnRemoveTweaks" Style="{StaticResource DangerButtonStyle}"/>
                </WrapPanel>
                <TextBlock x:Name="TweaksStatusText"
                           FontSize="12"
                           Margin="0,6,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
